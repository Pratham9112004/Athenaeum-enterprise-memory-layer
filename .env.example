# Postgres
POSTGRES_USER=athenaeum
POSTGRES_PASSWORD=athenaeum
POSTGRES_DB=athenaeum

# Backend
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production

# Required for chat (Feature 5). Document upload, processing, and semantic search
# all work without it; only the RAG chat endpoint needs a key and returns a clear
# 503 when it's missing.
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# ── Ingestion & retrieval tuning (optional; sensible defaults shown) ──────────
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# STORAGE_DIR=storage                 # where uploaded files are written
# MAX_UPLOAD_BYTES=26214400           # 25 MB
# CHUNK_SIZE_TOKENS=256               # ~model max sequence length
# CHUNK_OVERLAP_TOKENS=40
# RETRIEVAL_TOP_K=5

# Comma-separated list of allowed browser origins for CORS.
CORS_ORIGINS=http://localhost:5173

# Set true only when serving over HTTPS (marks the refresh cookie Secure).
COOKIE_SECURE=false
ENVIRONMENT=development

# Frontend (Vite reads this at build/serve time)
VITE_API_URL=http://localhost:8000/api/v1
